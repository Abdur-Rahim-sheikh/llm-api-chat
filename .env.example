# .env.example
# Copy this file to .env.local and fill in your values

# Supabase (get from: supabase.com → your project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# NOTE: Do NOT put API keys here.
# OpenAI and Gemini API keys are stored by the user in the Settings UI,
# then sent to /api/chat as a header — they never go in env files.
